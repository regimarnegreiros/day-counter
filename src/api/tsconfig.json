{
    "compilerOptions": {
        "module": "esnext",
        "alwaysStrict": true,
        "checkJs": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitThis": true,
        "resolveJsonModule": true,
        "rewriteRelativeImportExtensions": true,
        "strict": true
    },
    "exclude": [
        "node_modules", "out",
        "coverage", "babel.config.cjs" // tests files
    ]
}
